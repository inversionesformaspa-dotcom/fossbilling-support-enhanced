{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}
{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'support' %}

{% block meta_title %}{{ 'Palabras clave anti‑spam'|trans }}{% endblock %}

{% block breadcrumbs %}
<ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="{{ '/'|url(area: 'admin') }}"><svg class="icon"><use xlink:href="#home"/></svg></a></li>
    <li class="breadcrumb-item"><a href="{{ 'support'|url(area: 'admin') }}">{{ 'Support'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">{{ 'Palabras clave anti‑spam'|trans }}</li>
</ol>
{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">{{ 'Palabras clave anti‑spam'|trans }}</h3>
        <p class="card-subtitle">{{ 'Añade palabras para filtrar en el asunto o remitente. Los filtros Sieve se actualizarán automáticamente.'|trans }}</p>
    </div>

    {# Formulario para añadir #}
    <div class="card-body border-bottom pb-4">
        <form method="post" action="{{ 'support/spam-keywords'|url(area: 'admin') }}" class="row g-3 align-items-end">
            <input type="hidden" name="CSRFToken" value="{{ CSRFToken }}">
            <input type="hidden" name="action" value="add">
            <div class="col-md-4">
                <label class="form-label fw-bold">{{ 'Palabra clave'|trans }}</label>
                <input type="text" name="keyword" class="form-control" required placeholder="phishing, viagra, etc.">
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">{{ 'Buscar en'|trans }}</label>
                <select name="type" class="form-select">
    			<option value="subject">{{ 'Asunto'|trans }}</option>
    			<option value="from">{{ 'Remitente'|trans }}</option>
    			<option value="body">{{ 'Cuerpo'|trans }}</option>
    			<option value="header">{{ 'Cabecera genérica'|trans }}</option>
		</select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">{{ 'Mesa de soporte'|trans }}</label>
                <select name="helpdesk_id" class="form-select">
                    <option value="">{{ 'Global (todas las mesas)'|trans }}</option>
                    {% for hd in admin.support_helpdesk_get_list({}).list %}
                        <option value="{{ hd.id }}">{{ hd.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">{{ 'Añadir'|trans }}</button>
            </div>
        </form>
    </div>

    {# Lista de palabras #}
    <div class="card-body">
        <table class="table card-table table-vcenter table-striped">
            <thead>
                <tr>
                    <th>{{ 'Palabra'|trans }}</th>
                    <th>{{ 'Buscar en'|trans }}</th>
                    <th>{{ 'Mesa'|trans }}</th>
                    <th>{{ 'Fecha'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody>
                {% set keywords = admin.support_spamkw_get_list({}) %}
                {% set type_labels = {'subject': 'Asunto','from': 'Remitente','body': 'Cuerpo','header': 'Cabecera'} %}
                {% for kw in keywords %}
                <tr>
                    <td>{{ kw.keyword }}</td>
                    <td>{{ type_labels[kw.type] ?? kw.type }}</td>
                    <td>{{ kw.helpdesk_id ? admin.support_helpdesk_get({id: kw.helpdesk_id}).name : 'Global' }}</td>
                    <td>{{ kw.created_at }}</td>
                    <td>
                    <form method="post" action="{{ 'support/spam-keywords'|url(area: 'admin') }}" class="row g-3 align-items-end">
                            <input type="hidden" name="CSRFToken" value="{{ CSRFToken }}">
                            <input type="hidden" name="action" value="delete">
                            <input type="hidden" name="id" value="{{ kw.id }}">
                            <button type="submit" class="btn btn-icon btn-danger" title="{{ 'Eliminar'|trans }}">
                                <svg class="icon"><use xlink:href="#delete"/></svg>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="alert alert-info mt-3 small">
    <svg class="icon me-1"><use xlink:href="#info"/></svg>
    <strong>{{ 'Importante'|trans }}:</strong>
    {{ 'Los cambios en esta lista actualizan automáticamente los filtros Sieve (y SpamAssassin si está configurado). No es necesario reiniciar nada.'|trans }}
</div>
</div>
{% endblock %}
